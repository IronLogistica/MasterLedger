# Configurazione locale di MasterLedger
SECRET_KEY=sostituisci-con-una-chiave-lunga-e-casuale
COMPANY_NAME=La tua azienda
COMPANY_CODE=1000
# DATABASE_URL=postgresql://utente:password@host:porta/database

# Chiave API OpenAI, per il suggerimento AI delle scritture in Prima Nota.
# Senza questa variabile la funzione resta disattivata (nessun altro impatto).
# OPENAI_API_KEY=sk-...

# URL del servizio MasterLogistic-WMS (fonte di verità per le giacenze).
# Senza questa variabile, le operazioni di magazzino (entrata merci, consegne,
# produzione completata) si bloccano con un errore invece di proseguire con
# dati di giacenza sbagliati.
# MASTERLOGISTIC_URL=https://masterlogistic-wms-production.up.railway.app
